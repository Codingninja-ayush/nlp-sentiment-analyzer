# Kaggle API Key - NEVER upload this!
kaggle.json
kaggle*.json
.kaggle/

# Dataset files - too large for GitHub
*.zip
*.csv
*.tsv
amazon_reviews/
data/

# Python cache
__pycache__/
*.py[cod]
*$py.class
*.pyc
*.pyo
*.pyd

# Jupyter Notebook checkpoints
.ipynb_checkpoints/
*/.ipynb_checkpoints/*

# Environment variables
.env
.env.local
.env.*.local

# Virtual environments
venv/
env/
ENV/
.venv/

# IDE files
.vscode/
.idea/
*.swp
*.swo
*~

# OS files
.DS_Store
.DS_Store?
._*
Thumbs.db
desktop.ini

# Logs
*.log
logs/

# ngrok config
.ngrok/
ngrok.yml

# Temporary files
*.tmp
*.temp
temp/
tmp/
